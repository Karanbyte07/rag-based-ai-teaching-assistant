# Azure OpenAI Configuration

# Azure OpenAI Embedding Configuration
AZURE_EMBEDDING_ENDPOINT="https://<YOUR-AZURE-RESOURCE-NAME>.openai.azure.com/"
AZURE_EMBEDDING_MODEL="text-embedding-3-small"
AZURE_EMBEDDING_DEPLOYMENT="text-embedding-3-small"
AZURE_EMBEDDING_OPENAI_API_TYPE="azure"
AZURE_EMBEDDING_OPENAI_API_VERSION="2023-05-15"
AZURE_EMBEDDING_OPEN_API_KEY="<YOUR-AZURE-API-KEY>"
AZURE_EMBEDDING_CHUNK_SIZE=1000

# Azure OpenAI Whisper Configuration
AZURE_WHISPER_API_KEY="<YOUR-AZURE-API-KEY>"
AZURE_WHISPER_BASE_URL="https://<YOUR-AZURE-RESOURCE-NAME>.openai.azure.com/openai/deployments/<YOUR-WHISPER-DEPLOYMENT-NAME>"
